# RabbitMQ (Shared across all services)
RABBITMQ_URL=amqp://invexis:invexispass@rabbitmq:5672

# Redis (Shared for caching/pub-sub in notification/websocket/auth/etc.)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Retry Limits (optional; hardcoded in modules but can override if env vars added)
RETRY_LIMIT=3
RETRY_DELAY=5000

AUTH_SERVICE_URL=http://localhost:8001/auth
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
FRONTEND_URL=http://localhost:3002
IP_WHITELIST=127.0.0.1,::1