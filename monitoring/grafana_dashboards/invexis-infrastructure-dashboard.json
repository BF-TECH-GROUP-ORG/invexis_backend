{
  "dashboard": {
    "id": null,
    "title": "Invexis Infrastructure Monitoring",
    "tags": ["invexis", "infrastructure", "databases"],
    "style": "dark",
    "timezone": "browser",
    "editable": true,
    "panels": [
      {
        "id": 1,
        "title": "Database Connection Pools",
        "type": "timeseries",
        "targets": [
          {
            "expr": "pg_stat_database_numbackends{}",
            "legendFormat": "PostgreSQL {{datname}}",
            "refId": "A"
          },
          {
            "expr": "mysql_global_status_threads_connected{}",
            "legendFormat": "MySQL Connections",
            "refId": "B"
          },
          {
            "expr": "mongodb_connections{state=\"current\"}",
            "legendFormat": "MongoDB Connections",
            "refId": "C"
          },
          {
            "expr": "redis_connected_clients{}",
            "legendFormat": "Redis Connections",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "short"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Database Response Times",
        "type": "timeseries",
        "targets": [
          {
            "expr": "avg(pg_stat_statements_mean_time_ms) by (datname)",
            "legendFormat": "PostgreSQL {{datname}}",
            "refId": "A"
          },
          {
            "expr": "mysql_global_status_slow_queries / mysql_global_status_questions * 1000",
            "legendFormat": "MySQL Avg Query Time",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "ms"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Redis Memory Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "redis_memory_used_bytes",
            "legendFormat": "Used Memory",
            "refId": "A"
          },
          {
            "expr": "redis_memory_max_bytes",
            "legendFormat": "Max Memory",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "bytes"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 4,
        "title": "RabbitMQ Queue Sizes",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rabbitmq_queue_messages",
            "legendFormat": "{{queue}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "short"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 5,
        "title": "Disk Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100",
            "legendFormat": "Root Disk Usage %",
            "refId": "A"
          },
          {
            "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/var/lib/docker\"} / node_filesystem_size_bytes{mountpoint=\"/var/lib/docker\"}) * 100",
            "legendFormat": "Docker Disk Usage %",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "percent",
            "max": 100,
            "min": 0
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 16
        }
      },
      {
        "id": 6,
        "title": "Network I/O",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[5m]) * 8",
            "legendFormat": "{{device}} RX",
            "refId": "A"
          },
          {
            "expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[5m]) * 8",
            "legendFormat": "{{device}} TX",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "bps"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 16
        }
      },
      {
        "id": 7,
        "title": "Elasticsearch Cluster Health",
        "type": "stat",
        "targets": [
          {
            "expr": "elasticsearch_cluster_health_status",
            "legendFormat": "Cluster Status",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "options": {
                  "0": {
                    "color": "red",
                    "index": 0,
                    "text": "RED"
                  },
                  "1": {
                    "color": "yellow",
                    "index": 1,
                    "text": "YELLOW"
                  },
                  "2": {
                    "color": "green",
                    "index": 2,
                    "text": "GREEN"
                  }
                },
                "type": "value"
              }
            ]
          }
        },
        "gridPos": {
          "h": 4,
          "w": 8,
          "x": 0,
          "y": 24
        }
      },
      {
        "id": 8,
        "title": "Backup Status",
        "type": "stat",
        "targets": [
          {
            "expr": "time() - invexis_last_backup_timestamp",
            "legendFormat": "Time since last backup",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 86400
                },
                {
                  "color": "red",
                  "value": 172800
                }
              ]
            },
            "unit": "s"
          }
        },
        "gridPos": {
          "h": 4,
          "w": 8,
          "x": 8,
          "y": 24
        }
      },
      {
        "id": 9,
        "title": "SSL Certificate Expiry",
        "type": "stat",
        "targets": [
          {
            "expr": "probe_ssl_earliest_cert_expiry - time()",
            "legendFormat": "Days until expiry",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 604800
                },
                {
                  "color": "green",
                  "value": 2592000
                }
              ]
            },
            "unit": "s"
          }
        },
        "gridPos": {
          "h": 4,
          "w": 8,
          "x": 16,
          "y": 24
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s"
  }
}