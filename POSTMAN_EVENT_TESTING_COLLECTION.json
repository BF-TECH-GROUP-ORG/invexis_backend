  "item": [
    {
      "name": "🏭 Inventory Service",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "http://localhost:8007/health",
            "description": "Check if inventory service is running"
          }
        },
        {
          "name": "Create Product (Event Test)",
          "request": {
            "method": "POST",
            "url": "http://localhost:8007/v1/products",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyId\": \"company-123\",\n  \"name\": \"Test Product Event\",\n  \"slug\": \"test-product-event\",\n  \"description\": \"Testing event publishing\",\n  \"category\": \"cat-123\",\n  \"pricing\": {\n    \"basePrice\": 100,\n    \"costPrice\": 50,\n    \"sellingPrice\": 120\n  },\n  \"inventory\": {\n    \"quantity\": 50,\n    \"reorderLevel\": 10,\n    \"warehouse\": \"warehouse-123\"\n  },\n  \"status\": \"active\",\n  \"visibility\": \"public\"\n}"
            },
            "description": "Create product and verify inventory.product.created event is published"
          }
        },
        {
          "name": "Update Product (Event Test)",
          "request": {
            "method": "PUT",
            "url": "http://localhost:8007/v1/products/{{productId}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Product Event\",\n  \"pricing\": {\n    \"basePrice\": 150,\n    \"costPrice\": 60,\n    \"sellingPrice\": 180\n  },\n  \"status\": \"active\"\n}"
            },
            "description": "Update product and verify inventory.product.updated event is published"
          }
        },
        {
