{
    "info": {
        "name": "Invexis Backend - Complete Test Collection",
        "description": "Event-driven microservices - Auth, Company, Shop services",
        "version": "1.0.0"
    },
    "requests": [
        {
            "name": "1. Create Company",
            "method": "POST",
            "url": "http://localhost:8002/company-service/companies",
            "body": {
                "name": "Tech Solutions Inc",
                "domain": "techsolutions.com",
                "email": "admin@techsolutions.com",
                "phone": "+250788123456",
                "country": "Rwanda",
                "city": "Kigali",
                "tier": "Pro",
                "coordinates": {
                    "latitude": -1.9536,
                    "longitude": 29.8739
                },
                "category_ids": [
                    "cat-001",
                    "cat-002"
                ],
                "company_admin_id": "user-uuid-123"
            }
        },
        {
            "name": "2. Assign Company Admin",
            "method": "POST",
            "url": "http://localhost:8002/company-service/company-admins/company/{{companyId}}",
            "body": {
                "user_id": "user-uuid-456"
            }
        },
        {
            "name": "3. Get Company Admin",
            "method": "GET",
            "url": "http://localhost:8002/company-service/company-admins/company/{{companyId}}"
        },
        {
            "name": "4. Get Company Users (from Auth Service)",
            "method": "GET",
            "url": "http://localhost:8002/company-service/company-admins/company/{{companyId}}/users"
        },
        {
            "name": "5. Get Companies Administered by User",
            "method": "GET",
            "url": "http://localhost:8002/company-service/company-admins/user/{{userId}}"
        },
        {
            "name": "6. Remove Company Admin",
            "method": "DELETE",
            "url": "http://localhost:8002/company-service/company-admins/company/{{companyId}}"
        },
        {
            "name": "7. Assign User to Department",
            "method": "POST",
            "url": "http://localhost:8002/company-service/department-users",
            "body": {
                "company_id": "{{companyId}}",
                "department_id": "{{departmentId}}",
                "user_id": "user-uuid-789",
                "role": "seller"
            }
        },
        {
            "name": "8. Get Users in Department",
            "method": "GET",
            "url": "http://localhost:8002/company-service/department-users/department/{{departmentId}}"
        },
        {
            "name": "9. Get User's Departments",
            "method": "GET",
            "url": "http://localhost:8002/company-service/department-users/user/{{userId}}"
        },
        {
            "name": "10. Get User's Departments in Company",
            "method": "GET",
            "url": "http://localhost:8002/company-service/department-users/user/{{userId}}/company/{{companyId}}"
        },
        {
            "name": "11. Get Specific User-Department Assignment",
            "method": "GET",
            "url": "http://localhost:8002/company-service/department-users/user/{{userId}}/department/{{departmentId}}"
        },
        {
            "name": "12. Update User Role in Department (seller → manager)",
            "method": "PATCH",
            "url": "http://localhost:8002/company-service/department-users/user/{{userId}}/department/{{departmentId}}/role",
            "body": {
                "role": "manager"
            }
        },
        {
            "name": "13. Suspend User in Department",
            "method": "PATCH",
            "url": "http://localhost:8002/company-service/department-users/user/{{userId}}/department/{{departmentId}}/suspend"
        },
        {
            "name": "14. Reactivate User in Department",
            "method": "PATCH",
            "url": "http://localhost:8002/company-service/department-users/user/{{userId}}/department/{{departmentId}}/reactivate"
        },
        {
            "name": "15. Remove User from Department",
            "method": "DELETE",
            "url": "http://localhost:8002/company-service/department-users/user/{{userId}}/department/{{departmentId}}"
        },
        {
            "name": "16. Remove User from All Company Departments",
            "method": "DELETE",
            "url": "http://localhost:8002/company-service/department-users/user/{{userId}}/company/{{companyId}}"
        },
        {
            "name": "17. Get Active Users in Company",
            "method": "GET",
            "url": "http://localhost:8002/company-service/department-users/company/{{companyId}}/active"
        },
        {
            "name": "18. Create Shop",
            "method": "POST",
            "url": "http://localhost:9001/shop-service/shop",
            "body": {
                "company_id": "{{companyId}}",
                "name": "Kigali Downtown Store",
                "address_line1": "123 Main Street",
                "city": "Kigali",
                "region": "Kigali City",
                "country": "Rwanda",
                "postal_code": "1000",
                "latitude": -1.9465,
                "longitude": 29.8699,
                "timezone": "Africa/Kigali",
                "capacity": 50
            }
        },
        {
            "name": "19. Set Shop Operating Hours",
            "method": "PUT",
            "url": "http://localhost:9001/shop-service/shop/{{shopId}}/operating-hours",
            "body": {
                "hours": [
                    {
                        "day_of_week": 0,
                        "open_time": null,
                        "close_time": null
                    },
                    {
                        "day_of_week": 1,
                        "open_time": "09:00",
                        "close_time": "18:00"
                    },
                    {
                        "day_of_week": 2,
                        "open_time": "09:00",
                        "close_time": "18:00"
                    },
                    {
                        "day_of_week": 3,
                        "open_time": "09:00",
                        "close_time": "18:00"
                    },
                    {
                        "day_of_week": 4,
                        "open_time": "09:00",
                        "close_time": "18:00"
                    },
                    {
                        "day_of_week": 5,
                        "open_time": "09:00",
                        "close_time": "18:00"
                    },
                    {
                        "day_of_week": 6,
                        "open_time": "10:00",
                        "close_time": "20:00"
                    }
                ]
            }
        },
        {
            "name": "20. Update Specific Day Hours",
            "method": "PATCH",
            "url": "http://localhost:9001/shop-service/shop/{{shopId}}/operating-hours/1",
            "body": {
                "open_time": "08:00",
                "close_time": "19:00"
            }
        },
        {
            "name": "21. Get Shop Operating Hours",
            "method": "GET",
            "url": "http://localhost:9001/shop-service/shop/{{shopId}}/operating-hours"
        },
        {
            "name": "22. Check if Shop is Open Now",
            "method": "GET",
            "url": "http://localhost:9001/shop-service/shop/{{shopId}}/is-open"
        },
        {
            "name": "23. Clear Shop Operating Hours",
            "method": "DELETE",
            "url": "http://localhost:9001/shop-service/shop/{{shopId}}/operating-hours"
        },
        {
            "name": "24. Change Company Status to Suspended",
            "method": "PATCH",
            "url": "http://localhost:8002/company-service/companies/{{companyId}}/status",
            "body": {
                "status": "suspended"
            }
        },
        {
            "name": "25. Change Company Status to Active",
            "method": "PATCH",
            "url": "http://localhost:8002/company-service/companies/{{companyId}}/status",
            "body": {
                "status": "active"
            }
        },
        {
            "name": "26. User Login (Will be blocked if company suspended/shop closed)",
            "method": "POST",
            "url": "http://localhost:8001/auth/login",
            "body": {
                "identifier": "user@company.com",
                "password": "password123"
            }
        }
    ],
    "environment_variables": {
        "companyId": "comp-uuid-here",
        "departmentId": "dept-sales-uuid-here",
        "shopId": "shop-uuid-here",
        "userId": "user-uuid-here"
    },
    "notes": {
        "event_driven_flow": "All operations emit events via RabbitMQ. Auth Service receives events and updates caches.",
        "atomicity": "All DB changes + events are atomic (transaction-based)",
        "no_direct_api_calls": "Services communicate only via RabbitMQ events, not direct HTTP",
        "eventual_consistency": "Auth Service caches are updated async via events (5-10 second delay typical)"
    }
}