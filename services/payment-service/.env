# ==============================
# Payment Service Environment Configuration (.env)
# ==============================
# Load with dotenv: require('dotenv').config()
# Update secrets for production; use a secrets manager for security (AWS SSM, Vault, etc.)

# ------------------------------
# Database Configuration (PostgreSQL)
# ------------------------------
DB_HOST=payment-postgres
DB_PORT=5432
DB_USER=invexis
DB_PASSWORD=invexispass
DB_NAME=paymentdb

# PostgreSQL Pool Settings
PG_POOL_MIN=2
PG_POOL_MAX=20
PG_ACQUIRE_TIMEOUT=60000

# ------------------------------
# Service Configuration
# ------------------------------
PORT=8009

# ------------------------------
# MTN Mobile Money (MoMo) Configuration
# ------------------------------
