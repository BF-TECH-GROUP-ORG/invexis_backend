# Payment Service Environment Configuration (.env)
# This file configures the payment service for database, ports, and gateway integrations.
# Load with dotenv in your app (e.g., require('dotenv').config()).
# Update secrets for production; use a secrets manager (e.g., AWS SSM) for security.

# Database Configuration (PostgreSQL via Knex.js)
DB_HOST=payment-postgres
DB_PORT=5432
DB_USER=invexis
DB_PASSWORD=invexispass
DB_NAME=paymentdb

# Service Port
PORT=8009

# PostgreSQL Pool Settings (for high traffic)
PG_POOL_MIN=2
PG_POOL_MAX=20
PG_ACQUIRE_TIMEOUT=60000

# RabbitMQ (for events/cross-service sync)
RABBITMQ_URL=amqp://invexis:invexispass@rabbitmq:5672

# JWT Secret (for authentication)
JWT_SECRET=your-jwt-secret-change-in-production

# CORS Origin
CORS_ORIGIN=*

