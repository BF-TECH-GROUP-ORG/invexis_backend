PORT = 8008
NODE_ENV=development

# Mongo
MONGO_URI=mongodb://mongo:27017/notificationdb

# Redis (shared)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ (shared)
RABBITMQ_URL=amqp://invexis:invexispass@rabbitmq:5672
RABBITMQ_RETRY_LIMIT=3
RABBITMQ_RETRY_DELAY=5000
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_RECONNECT_BASE=1000
MAX_RECONNECT_ATTEMPTS=10

# Email (Nodemailer - Mailtrap for dev)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_mail_user
EMAIL_PASS=your_mail_pass
EMAIL_FROM=no-reply@invexis.com

# Twilio
TWILIO_SID=ACxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# Firebase
FIREBASE_PROJECT_ID=invexis
FIREBASE_CLIENT_EMAIL=firebase@invexis.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."

# Socket (websocket-service)
SOCKET_SERVER_URL=http://localhost:3002