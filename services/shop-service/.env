# ====== Development ======
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=shop_service_dev
DB_USER=postgres
DB_PASSWORD=your_dev_password

# ====== Staging ======
STAGING_DB_HOST=127.0.0.1
STAGING_DB_PORT=5432
STAGING_DB_NAME=shop_service_staging
STAGING_DB_USER=postgres
STAGING_DB_PASSWORD=your_staging_password

# ====== Production ======
# For production, you can use a single DATABASE_URL (Heroku style) or individual vars
DATABASE_URL=postgres://prod_user:prod_password@prod_host:5432/shop_service_prod

# ====== General Settings ======
NODE_ENV=development
