# Example environment variables for audit-service
# Copy to .env (do NOT commit real secrets)

# Application
PORT=8003
NODE_ENV=development
SESSION_SECRET=change_this_to_a_secure_value

# MongoDB
# Provide full connection string or rely on the default in config/db.js
MONGO_URI=mongodb://root:invexispass@localhost:27017/auditdb?authSource=admin

# Redis (optional - shared client will use defaults if not provided)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ (optional)
RABBITMQ_URL=amqp://invexis:invexispass@localhost:5672
RABBITMQ_RETRY_DELAY=5000
RABBITMQ_PREFETCH_COUNT=10

# Optional upload path (if service handles files)
UPLOAD_PATH=./uploads

# Notes:
# - When running inside Docker Compose the shared services are mounted at /app/shared, so index will try to use them.
# - The service can still start locally without shared modules because it falls back to no-op mocks when they are not available.
