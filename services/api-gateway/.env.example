PORT=8000
NODE_ENV=development

# Gateway CORS/Origins: comma-separated list or '*' for all
# Example: CORS_ORIGIN="http://localhost:3000,http://localhost:5000"
CORS_ORIGIN=http://localhost:3000

# Internal management key (protect /internal endpoints)
INTERNAL_API_KEY=change-me-in-prod

# Redis (optional but recommended for multi-instance origin sync and caching)
REDIS_URL=/app/shared/redis

# JWT settings used for proxy auth verification (example values)
JWT_SECRET=sdjnjkdjafd8a79d7fa76yuadsjjgdsx786754w21qt??vcrytv.bjahsgtd76y3498hnjf//dkjsfa
JWT_ISSUER=auth-service.invexis.local
JWT_AUDIENCE=invexis-api-gateway

# Optional: public URL for frontends (used in docs/links)
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000
